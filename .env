# === Local Inference (Ollama) ===
# We point this to your local computer's Ollama service
LLM_API_KEY=local_development
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=llama3

# === Local Memory (ChromaDB) ===
# This tells the system to save data to your local ChromaDB container
MEMORY_BACKEND=chromadb
CHROMA_SERVER_HOST=chromadb
CHROMA_SERVER_HTTP_PORT=8000

# === Knowledge Graph (Neo4j) ===
# Internal connection settings for the graph database
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# === Stock Market API Placeholder ===
# You can leave these as is for now
MARKET_DATA_API_KEY=placeholder
NEWS_API_KEY=placeholder
